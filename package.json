{
  "name": "navanalysis",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:full": "concurrently --names \"SERVER,VITE\" --prefix-colors \"green,cyan\" \"npm run start --workspace=navanalysis-backend\" \"npm run dev --workspace=navanalysis-frontend\"",
    "build": "npm run build --workspace=navanalysis-frontend",
    "install:all": "npm install"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  }
}
